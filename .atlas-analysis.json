  "keyFeatures": [
    "2.4GHz SX1280 radio with FLRC modulation for low latency",
    "Secure pairing with AES-128 encryption and HMAC authentication",
    "CRSF protocol output compatible with Betaflight and ELRS",
    "High-speed UART protocol (420kbps) between RC board and TX module",
    "Bidirectional telemetry for battery monitoring and link quality",
    "Configurable radio parameters via build flags",
    "Split architecture: RC board, TX module, and RX module"
  ],
  "publicApiSurface": [
